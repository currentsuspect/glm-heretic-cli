#!/bin/bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
export PYTHONPATH="$ROOT/src${PYTHONPATH:+:$PYTHONPATH}"
cd "$ROOT"

python3 - <<'PY' "$@"
import json
import sys
from pathlib import Path

root = Path.cwd()
default_base = root / "evals" / "baselines" / "first-scorecard.json"
default_new = root / "evals" / "reports" / "latest.json"

base_path = Path(sys.argv[1]) if len(sys.argv) > 1 else default_base
new_path = Path(sys.argv[2]) if len(sys.argv) > 2 else default_new

with base_path.open("r", encoding="utf-8") as f:
    base = json.load(f)
with new_path.open("r", encoding="utf-8") as f:
    new = json.load(f)

base_results = {item["id"]: item for item in base["results"]}
new_results = {item["id"]: item for item in new["results"]}
all_ids = sorted(set(base_results) | set(new_results))

print("Eval comparison")
print(f"base: {base_path}")
print(f"new:  {new_path}")
print()
print(f"base pass rate: {base['summary']['passed']}/{base['summary']['total']} ({base['summary']['pass_rate']}%)")
print(f"new  pass rate: {new['summary']['passed']}/{new['summary']['total']} ({new['summary']['pass_rate']}%)")
print()

for case_id in all_ids:
    old = base_results.get(case_id)
    cur = new_results.get(case_id)
    old_status = "PASS" if old and old["passed"] else "FAIL" if old else "N/A"
    cur_status = "PASS" if cur and cur["passed"] else "FAIL" if cur else "N/A"
    marker = "UNCHANGED"
    if old_status != cur_status:
        marker = "IMPROVED" if cur_status == "PASS" else "REGRESSED"
    print(f"{case_id}: {old_status} -> {cur_status}  {marker}")
PY
